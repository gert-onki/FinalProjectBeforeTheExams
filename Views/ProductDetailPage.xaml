<Page
    x:Class="shittyEtsy.Views.ProductDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#111111">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxWidth="860" Margin="32,24,32,32" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#8592; Back"
                        Click="BackButton_Click"
                        Background="#2A2A2A"
                        Foreground="White"
                        Padding="12,7"
                        CornerRadius="6"/>

                <Button Grid.Column="2"
                        x:Name="GoToCartButton"
                        Click="GoToCartButton_Click"
                        Background="#2A2A2A"
                        Foreground="White"
                        Padding="12,7"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#128722;" FontSize="16"/>
                        <TextBlock x:Name="CartCountText" Text="Cart (0)" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

         
            <Border Grid.Row="1"
                    Background="#1A1A1A"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                
                    <Border Grid.Column="0"
                            Background="#222222"
                            CornerRadius="10"
                            Width="260"
                            Height="260"
                            VerticalAlignment="Top">
                        <Image x:Name="ProductImage"
                               Stretch="UniformToFill"
                             />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0" Spacing="10">

                        <TextBlock x:Name="ProductName"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="ProductPrice"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#4CAF50"/>

                        <TextBlock x:Name="SellerName"
                                   FontSize="13"
                                   Foreground="#888888"/>

                        <Border Background="#222222" CornerRadius="6" Padding="0" Margin="0,4,0,4">
                            <StackPanel Padding="14,10" Spacing="8">
                                <TextBlock Text="Product details"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#888888"
                                           CharacterSpacing="60"/>

                                <Grid ColumnSpacing="12" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Material" Foreground="#666666" FontSize="13"/>
                                    <TextBlock x:Name="DetailMaterial" Grid.Row="0" Grid.Column="1" Foreground="#CCCCCC" FontSize="13"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Production time" Foreground="#666666" FontSize="13"/>
                                    <TextBlock x:Name="DetailProductionTime" Grid.Row="1" Grid.Column="1" Foreground="#CCCCCC" FontSize="13"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Complexity" Foreground="#666666" FontSize="13"/>
                                    <TextBlock x:Name="DetailComplexity" Grid.Row="2" Grid.Column="1" Foreground="#CCCCCC" FontSize="13"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Durability" Foreground="#666666" FontSize="13"/>
                                    <TextBlock x:Name="DetailDurability" Grid.Row="3" Grid.Column="1" Foreground="#CCCCCC" FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="ProductDescription"
                                   Foreground="#AAAAAA"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>

                        <TextBlock x:Name="UniqueFeatures"
                                   Foreground="#777777"
                                   FontSize="13"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button x:Name="AddToCartButton"
                                    Content="Add to cart"
                                    Click="AddToCartButton_Click"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    Padding="16,10"
                                    FontSize="14"
                                    CornerRadius="6"
                                    Visibility="Collapsed"/>

                            <Button x:Name="EditButton"
                                    Content="Edit product"
                                    Click="EditButton_Click"
                                    Background="#2196F3"
                                    Foreground="White"
                                    Padding="16,10"
                                    FontSize="14"
                                    CornerRadius="6"
                                    Visibility="Collapsed"/>
                        </StackPanel>

                        <TextBlock x:Name="CartFeedback"
                                   Foreground="#4CAF50"
                                   FontSize="13"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>


            <Border Grid.Row="2"
                    Background="#1A1A1A"
                    CornerRadius="12"
                    Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="Reviews"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <ItemsControl x:Name="ReviewsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#222222"
                                        CornerRadius="8"
                                        Padding="16,12"
                                        Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Stars}"
                                                       Foreground="#FFD700"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding BuyerName}"
                                                       Foreground="#888888"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Comment}"
                                                   Foreground="#CCCCCC"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoReviewsText"
                               Text="No reviews yet."
                               Foreground="#555555"
                               FontSize="13"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
