<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="shittyEtsy.Views.EditProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:shittyEtsy.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="40" Spacing="16" MaxWidth="600" HorizontalAlignment="Center">
            <TextBlock Text="Edit Product" FontSize="28" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Product Name *" FontWeight="SemiBold"/>
            <TextBox x:Name="NameInput" PlaceholderText="e.g. Handmade Ceramic Mug"/>
            <TextBlock Text="Product Price *" FontWeight="SemiBold"/>
            <NumberBox x:Name="PriceInput" PlaceholderText="e.g. 10.99"/>
            <TextBlock Text="Category *" FontWeight="SemiBold"/>
            <ComboBox x:Name="CategoryInput" PlaceholderText="Select a category" HorizontalAlignment="Stretch"/>
            <TextBlock Text="Description *" FontWeight="SemiBold"/>
            <TextBox x:Name="DescriptionInput"
                     PlaceholderText="Describe your product in detail..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="120"/>
            <TextBlock Text="Material" FontWeight="SemiBold"/>
            <TextBox x:Name="MaterialInput" PlaceholderText="e.g. Oak wood, Sterling silver, Cotton"/>
            <TextBlock Text="Production Time" FontWeight="SemiBold"/>
            <ComboBox x:Name="ProductionTimeInput" PlaceholderText="How long to make?" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Ready to ship"/>
                <ComboBoxItem Content="1-3 days"/>
                <ComboBoxItem Content="3-7 days"/>
                <ComboBoxItem Content="1-2 weeks"/>
                <ComboBoxItem Content="2-4 weeks"/>
                <ComboBoxItem Content="1+ month"/>
            </ComboBox>
            <TextBlock Text="Complexity" FontWeight="SemiBold"/>
            <ComboBox x:Name="ComplexityInput" PlaceholderText="Select complexity" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Simple"/>
                <ComboBoxItem Content="Moderate"/>
                <ComboBoxItem Content="Complex"/>
                <ComboBoxItem Content="Highly Complex"/>
            </ComboBox>
            <TextBlock Text="Durability" FontWeight="SemiBold"/>
            <ComboBox x:Name="DurabilityInput" PlaceholderText="Select durability" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Fragile"/>
                <ComboBoxItem Content="Moderate"/>
                <ComboBoxItem Content="Durable"/>
                <ComboBoxItem Content="Very Durable"/>
            </ComboBox>
            <TextBlock Text="Unique Features" FontWeight="SemiBold"/>
            <TextBox x:Name="UniqueFeaturesInput"
                     PlaceholderText="What makes your product special? e.g. Personalized, Eco-friendly..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80"/>
            <Button x:Name="PickImageButton" Content="Choose Image" Click="PickImageButton_Click"/>
            <Image x:Name="ImagePreview" MaxHeight="200" Margin="0,8,0,0" Stretch="Uniform" Visibility="Collapsed"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button x:Name="SaveProductButton"
                        Content="Save Changes"
                        HorizontalAlignment="Left"
                        Click="SaveProductButton_Click"
                        Background="#4CAF50"
                        Foreground="White"/>
                <Button x:Name="GoBackButton"
                        Content="Go Back"
                        HorizontalAlignment="Left"
                        Click="CancelButton_Click"
                        Background="#757575"
                        Foreground="White"/>
                <Button x:Name="DeleteButton"
                        Content="Delete Product"
                        HorizontalAlignment="Left"
                        Click="DeleteButton_Click"
                        Background="#D32F2F"
                        Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page> 