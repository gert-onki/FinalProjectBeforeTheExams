<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="shittyEtsy.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:shittyEtsy.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:localData="using:shittyEtsy.Data.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Home page"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#FFFFFF"
                   Margin="0,20,0,12"/>

        <ListView Grid.Row="1"
                  x:Name="productsList"
                  SelectionMode="None"
                  Padding="16,0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,6"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="localData:Products">
                    <Border Background="#1E1E1E"
                            CornerRadius="10"
                            Padding="16"
                            BorderBrush="#333333"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

    
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind Name}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFF"/>

                      
                          
                            </Grid>

                  
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind Description}"
                                       TextWrapping="Wrap"
                                       Foreground="#AAAAAA"
                                       FontSize="14"
                                       Margin="0,0,0,12"/>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,0,0,12">

                            
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Material:" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Material}"
                                                   FontSize="12"
                                                   Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>

                              
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Complexity:" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Complexity}"
                                                   FontSize="12"
                                                   Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>

                              
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Durability:" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Durability}"
                                                   FontSize="12"
                                                   Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>

               
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="8,4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Production Time:" FontSize="12"/>
                                        <TextBlock Text="{x:Bind ProductionTime}"
                                                   FontSize="12"
                                                   Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind UniqueFeatures}"
                                           FontSize="13"
                                           FontStyle="Italic"
                                           Foreground="#888888"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind CreatedAt}"
                                           FontSize="12"
                                           Foreground="#555555"
                                           VerticalAlignment="Center"/>
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Text="Home page" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFFFFF"/>
        <Button Content="Go to Create Product" Click="GoToCreateProductPage_Click" Padding="15,10" Background="#4CAF50" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50,0,0" CornerRadius="4"/>
    </Grid>
</Page>