<Page
    x:Class="shittyEtsy.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:shittyEtsy.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:localData="using:shittyEtsy.Data.Models"
    xmlns:localViews="using:shittyEtsy.Views"
    xmlns:converters="using:shittyEtsy.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,16,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Home page"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#FFFFFF"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Click="GoToCartPage_Click"
                    Background="#2A2A2A"
                    Foreground="White"
                    Padding="12,7"
                    CornerRadius="6"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="&#128722;" FontSize="16"/>
                    <TextBlock x:Name="CartHeaderText" Text="Cart (0)" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Background="#1A1A1A"
                BorderBrush="#333333"
                BorderThickness="0,1,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">

                <TextBox x:Name="SearchBox"
                         PlaceholderText="Search by name..."
                         Width="200"
                         TextChanged="Filter_Changed"
                         Background="#2A2A2A"
                         Foreground="White"
                         BorderBrush="#444444"/>

                <ComboBox x:Name="CategoryFilter"
                          PlaceholderText="All Categories"
                          Width="160"
                          SelectionChanged="Filter_Changed"
                          Background="#2A2A2A"
                          Foreground="White"/>

                <ComboBox x:Name="ComplexityFilter"
                          PlaceholderText="All Complexities"
                          Width="160"
                          SelectionChanged="Filter_Changed"
                          Background="#2A2A2A"
                          Foreground="White">
                    <ComboBoxItem Content="All Complexities" Tag=""/>
                    <ComboBoxItem Content="Low"/>
                    <ComboBoxItem Content="Medium"/>
                    <ComboBoxItem Content="High"/>
                </ComboBox>

                <ComboBox x:Name="MaterialFilter"
                          PlaceholderText="All Materials"
                          Width="160"
                          SelectionChanged="Filter_Changed"
                          Background="#2A2A2A"
                          Foreground="White"/>

                <Button Content="Clear Filters"
                        Click="ClearFilters_Click"
                        Background="#555555"
                        Foreground="White"
                        Padding="10,6"
                        CornerRadius="4"/>
            </StackPanel>
        </Border>

        <GridView Grid.Row="2"
                  x:Name="productsList"
                  Padding="16"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="localViews:ProductViewModel">
                    <Border Width="280"
                            Background="#1E1E1E"
                            CornerRadius="10"
                            Margin="8"
                            BorderBrush="#2D2D2D"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="180"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                     
                            <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="#2A2A2A">
                                <Image Source="{x:Bind Image}"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Row="1" Padding="14,10,14,6" Spacing="4">
                                <TextBlock Text="{x:Bind Name}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#FFFFFF"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Text="{x:Bind Description}"
                                           TextWrapping="Wrap"
                                           Foreground="#AAAAAA"
                                           FontSize="13"
                                           MaxLines="3"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Text="{x:Bind Price}"
                                           Foreground="#4CAF50"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        Padding="14,0,14,6">
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="7,3">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Material:" FontSize="11" Foreground="#777777"/>
                                        <TextBlock Text="{x:Bind Material}" FontSize="11" Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="7,3">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="Complexity:" FontSize="11" Foreground="#777777"/>
                                        <TextBlock Text="{x:Bind Complexity}" FontSize="11" Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                   
                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        Padding="14,0,14,8">
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="6,2">
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="Durability:" FontSize="11" Foreground="#777777"/>
                                        <TextBlock Text="{x:Bind Durability}" FontSize="11" Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#2A2A2A" CornerRadius="4" Padding="6,2">
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <TextBlock Text="Production:" FontSize="11" Foreground="#777777"/>
                                        <TextBlock Text="{x:Bind ProductionTime}" FontSize="11" Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        
                            <Border Grid.Row="4"
                                    Background="#161616"
                                    CornerRadius="0,0,10,10"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                    <Button Content="View"
                                            Click="ViewProduct_Click"
                                            Tag="{x:Bind ProductId}"
                                            Background="#333333"
                                            Foreground="White"
                                            Padding="10,5"
                                            FontSize="12"
                                            CornerRadius="4"/>

                                    <Button Content="Edit"
                                            Click="EditProduct_Click"
                                            Tag="{x:Bind ProductId}"
                                            Visibility="{x:Bind IsOwnProduct, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="#2196F3"
                                            Foreground="White"
                                            Padding="10,5"
                                            FontSize="12"
                                            CornerRadius="4"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Button Grid.Row="3"
                Content="+ Create product"
                Click="GoToCreateProductPage_Click"
                Padding="15,10"
                Background="#4CAF50"
                Foreground="White"
                FontSize="14"
                HorizontalAlignment="Center"
                Margin="0,12,0,16"
                CornerRadius="4"/>
    </Grid>
</Page>
