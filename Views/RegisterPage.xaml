<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="shittyEtsy.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:shittyEtsy.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
        <Grid VerticalAlignment="Center">
            <StackPanel Width="350" Spacing="15" HorizontalAlignment="Center" Padding="20">
              

                <TextBlock Text="Join the Adventure" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFFFFF"/>
                <TextBlock Text="Create your account" FontSize="12" HorizontalAlignment="Center" Foreground="#B0B0B0"/>

                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#404040">
                    <StackPanel Orientation="Vertical" Spacing="12">
                        <StackPanel Orientation="Vertical" Spacing="6">
                            <TextBlock Text="name" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                            <TextBox x:Name="nameInput" PlaceholderText="Choose a username" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Spacing="6">
                            <TextBlock Text="Email" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                            <TextBox x:Name="EmailInput" PlaceholderText="Enter an email" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Spacing="6">
                            <TextBlock Text="Password" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="PasswordInput" PlaceholderText="Create a password" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical" Spacing="6">
                            <TextBlock Text="Confirm Password" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="ConfirmPasswordInput" PlaceholderText="Confirm password" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                        </StackPanel>

                        <TextBlock x:Name="ErrorText" Foreground="#FF6B6B" Visibility="Collapsed" TextWrapping="Wrap"/>

                        <Button Content="Create Account" Click="RegisterButton_Click" Padding="15,10" Background="#4CAF50" Foreground="White" FontSize="14" HorizontalAlignment="Stretch" CornerRadius="4"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Vertical" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account?" HorizontalAlignment="Center" Foreground="#B0B0B0" FontSize="12"/>
                    <Button Content="Sign In" Click="GoToLoginPage_Click" Background="#2196F3" Foreground="White" Padding="12,8" HorizontalAlignment="Center" CornerRadius="4"/>
                    <Button Content="Go Back" Click="GoBackButton_Click" Background="#757575" Foreground="White" Padding="12,8" HorizontalAlignment="Center" CornerRadius="4"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
